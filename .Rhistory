title, ". ", off_title, ", ",
loc_city, ", ", loc_state, ". "
)
} else {
cit <- paste0(
"'{{< pagebreak >}}' \n",
"\n",
"Please cite this publication as \n",
"\n",
"SEDAR. ", year, ". ", title,
"SEDAR, North Charleston SC. XXpp. ",
"available online at: http://sedarweb.org/"
)
}
# Add citation as .qmd to add into template
return(cit)
}
